rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (
          request.auth.token.email == "VisiFisnawati@gmail.com" ||
          request.auth.token.email == "aditresa10@gmail.com" ||
          request.auth.token.email == "aditresa12@gmail.com" ||
          request.auth.token.email == "timmuturs@optimus.local" ||
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
        );
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.unitId;
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidUser(data) {
      return data.keys().hasOnly(['uid', 'username', 'role', 'unitName', 'createdAt']) &&
             data.uid is string && data.uid.size() > 0 && data.uid.size() < 100 &&
             data.username is string && data.username.size() > 0 && data.username.size() < 100 &&
             data.role in ['unit', 'admin'] &&
             (!('unitName' in data) || (data.unitName is string && data.unitName.size() < 100)) &&
             data.createdAt is string;
    }

    function isValidIndikatorMaster(data) {
      let fields = [
        'id', 'kategori', 'judul', 'dasar_pemikiran', 'dimensi_mutu', 'tujuan', 
        'definisi_operasional', 'tipe', 'satuan', 'numerator', 'denominator', 
        'target', 'kriteria', 'formula', 'metode_pengumpulan', 'sumber_data', 
        'cara_sampling', 'instrumen', 'besar_sampel', 'periode_pengumpulan', 
        'periode_analisis', 'penyajian', 'penanggung_jawab', 'created_by', 'created_at',
        'updated_at', 'updated_by'
      ];
      return hasRequiredFields(['kategori', 'judul']) && 
             hasOnlyAllowedFields(fields) &&
             (!('id' in data) || data.id is string) &&
             data.kategori in ['INM', 'IMP-RS', 'IMP-Unit', 'SPM'] &&
             data.judul is string && data.judul.size() > 0 &&
             (!('dasar_pemikiran' in data) || data.dasar_pemikiran is string) &&
             (!('dimensi_mutu' in data) || data.dimensi_mutu is list || data.dimensi_mutu is string) &&
             (!('tujuan' in data) || data.tujuan is string) &&
             (!('definisi_operasional' in data) || data.definisi_operasional is string) &&
             (!('tipe' in data) || data.tipe in ['Struktur', 'Proses', 'Outcome']) &&
             (!('satuan' in data) || data.satuan is string) &&
             (!('numerator' in data) || data.numerator is string) &&
             (!('denominator' in data) || data.denominator is string) &&
             (!('target' in data) || data.target is string || data.target is number) &&
             (!('kriteria' in data) || data.kriteria is string) &&
             (!('formula' in data) || data.formula is string) &&
             (!('metode_pengumpulan' in data) || data.metode_pengumpulan is string) &&
             (!('sumber_data' in data) || data.sumber_data is string) &&
             (!('cara_sampling' in data) || data.cara_sampling is string) &&
             (!('instrumen' in data) || data.instrumen is string) &&
             (!('besar_sampel' in data) || data.besar_sampel is string || data.besar_sampel is number) &&
             (!('periode_pengumpulan' in data) || data.periode_pengumpulan is list || data.periode_pengumpulan is string) &&
             (!('periode_analisis' in data) || data.periode_analisis is list || data.periode_analisis is string) &&
             (!('penyajian' in data) || data.penyajian is list || data.penyajian is string) &&
             (!('penanggung_jawab' in data) || data.penanggung_jawab is string) &&
             (!('created_by' in data) || data.created_by is string) &&
             (!('created_at' in data) || data.created_at is string) &&
             (!('updated_by' in data) || data.updated_by is string) &&
             (!('updated_at' in data) || data.updated_at is string);
    }

    function isValidDataIndikator(data) {
      return data.keys().hasOnly(['id', 'unit', 'sub_unit', 'kategori', 'indikator_id', 'nama_indikator', 'nilai', 'numerator_value', 'denominator_value', 'analisis', 'rencana_tindak_lanjut', 'tanggal', 'bulan', 'tahun', 'created_by', 'created_at']) &&
             (!('id' in data) || (data.id is string && data.id.size() > 0 && data.id.size() < 100)) &&
             data.unit is string && data.unit.size() > 0 && data.unit.size() < 100 &&
             (!('sub_unit' in data) || data.sub_unit == null || (data.sub_unit is string && data.sub_unit.size() < 100)) &&
             data.kategori is string && data.kategori in ['INM', 'IMP-RS', 'IMP-Unit', 'SPM'] &&
             data.indikator_id is string && data.indikator_id.size() > 0 && data.indikator_id.size() < 100 &&
             data.nama_indikator is string && data.nama_indikator.size() > 0 && data.nama_indikator.size() < 200 &&
             data.nilai is number &&
             (!('numerator_value' in data) || data.numerator_value == null || data.numerator_value is number) &&
             (!('denominator_value' in data) || data.denominator_value == null || data.denominator_value is number) &&
             (!('analisis' in data) || data.analisis is string) &&
             (!('rencana_tindak_lanjut' in data) || data.rencana_tindak_lanjut is string) &&
             data.tanggal is string && data.tanggal.size() > 0 && data.tanggal.size() < 20 &&
             data.bulan is number &&
             data.tahun is number &&
             data.created_by is string && data.created_by.size() > 0 && data.created_by.size() < 100 &&
             data.created_at is string;
    }

    function isValidSettings(data) {
      return data.keys().hasOnly(['id', 'logoUrl', 'appName', 'updatedAt']) &&
             data.id is string && data.id == 'general' &&
             data.logoUrl is string && data.logoUrl.size() < 1000000 &&
             data.appName is string && data.appName.size() > 0 && data.appName.size() < 50 &&
             data.updatedAt is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================
    match /users/{userId} {
      allow read: if isAuthenticated();
      // Allow user to create their own profile, but they can only assign 'unit' role unless they are an admin.
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && 
                    isOwner(userId) && request.resource.data.uid == userId &&
                    ((request.resource.data.role == 'unit') || isAdmin());
      // Allow user to update their own profile, but they cannot change their role.
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && 
                    ((isOwner(userId) && request.resource.data.uid == resource.data.uid && request.resource.data.role == resource.data.role) || isAdmin());
      allow delete: if isAdmin();
    }

    match /indikator_master/{indikatorId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin() && isValidIndikatorMaster(request.resource.data);
    }

    match /data_indikator/{dataId} {
      allow read: if isAuthenticated() && (isAdmin() || resource.data.created_by == request.auth.uid);
      allow create: if isAuthenticated() && isValidDataIndikator(request.resource.data) && 
                    (isAdmin() || (request.resource.data.created_by == request.auth.uid));
      allow update: if isAuthenticated() && isValidDataIndikator(request.resource.data) && 
                    (isAdmin() || (resource.data.created_by == request.auth.uid && request.resource.data.created_by == resource.data.created_by));
      allow delete: if isAuthenticated() && (isAdmin() || resource.data.created_by == request.auth.uid);
    }

    match /settings/{settingId} {
      allow read: if true; // Publicly readable for welcome screen
      allow create, update, delete: if isAdmin() && isValidSettings(request.resource.data);
    }
  }
}
